{
  "$schema": "https://wails.io/schemas/config.v2.json",
  "name": "twins-gui",
  "outputfilename": "twins-gui",
  "frontend:install": "npm install",
  "frontend:build": "npm run build",
  "frontend:dev:watcher": "npm run dev",
  "frontend:dev:serverUrl": "http://localhost:5173",
  "debounceMS": 100,
  "appargs": "",
  "runNonNativeBuildHooks": false,
  "author": {
    "name": "TWINS Development Team",
    "email": "support@twins.cryptocurrency"
  },
  "info": {
    "companyName": "TWINS Foundation",
    "productName": "TWINS Wallet",
    "productVersion": "1.0.0",
    "copyright": "Copyright © 2024 TWINS Foundation",
    "comments": "Modern desktop wallet for TWINS cryptocurrency"
  },
  "nsisType": "multiple",
  "obfuscated": false,
  "garbleargs": "-literals -tiny -seed=random"
}
