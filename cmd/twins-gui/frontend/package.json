    "bignumber.js": "^9.3.1",
    "clsx": "^2.1.1",
    "i18next": "^25.7.3",
    "i18next-browser-languagedetector": "^8.2.0",
    "immer": "^11.1.4",
    "lucide-react": "^0.574.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.64.0",
    "react-i18next": "^16.5.0",
    "react-router": "^7.13.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
