# TWINS Environment Variables Example
# ====================================
# Copy this file to .env and fill in your values.
# Environment variables override values in YAML config files.
# Format: TWINS_{SECTION}_{KEY} (uppercase, underscores)

# ==========================================
# Network Settings
# ==========================================
TWINS_NETWORK=mainnet
TWINS_NETWORK_PORT=37817
TWINS_NETWORK_MAX_PEERS=125
TWINS_NETWORK_LISTEN_ADDR=0.0.0.0
TWINS_NETWORK_EXTERNAL_IP=
TWINS_NETWORK_PROXY=
TWINS_NETWORK_ONION_PROXY=

# ==========================================
# RPC Server Authentication
# ==========================================
# REQUIRED for production - use strong random credentials
TWINS_RPC_ENABLED=true
TWINS_RPC_USERNAME=
TWINS_RPC_PASSWORD=
TWINS_RPC_PORT=37818
TWINS_RPC_HOST=127.0.0.1

# ==========================================
# Wallet Settings
# ==========================================
TWINS_WALLET_DISABLED=false
TWINS_WALLET_FILE=wallet.dat
TWINS_WALLET_KEY_POOL=100
TWINS_WALLET_TX_FEE=0.0001
TWINS_WALLET_USE_HD=true
TWINS_WALLET_RESCAN=false

# ==========================================
# Staking Settings
# ==========================================
TWINS_STAKING_ENABLED=false
TWINS_STAKING_RESERVE_BALANCE=0

# ==========================================
# Masternode Configuration
# ==========================================
TWINS_MASTERNODE_ENABLED=false
TWINS_MASTERNODE_KEY=
TWINS_MASTERNODE_TIER=bronze
TWINS_MASTERNODE_COLLATERAL_TX=
TWINS_MASTERNODE_COLLATERAL_IDX=0
TWINS_MASTERNODE_SERVICE_ADDR=
TWINS_MASTERNODE_PAYMENT_ADDR=
TWINS_MASTERNODE_DONATION_ADDR=
TWINS_MASTERNODE_DONATION_PCT=0

# ==========================================
# Database Settings
# ==========================================
TWINS_DATA_DIR=./data
TWINS_DATABASE_TYPE=pebble
TWINS_DATABASE_CACHE_SIZE=512
TWINS_DATABASE_MAX_OPEN_FILES=1000
TWINS_DATABASE_SYNC_WRITES=true
TWINS_DATABASE_COMPRESSION=snappy

# ==========================================
# Logging Settings
# ==========================================
TWINS_LOG_LEVEL=info
TWINS_LOG_FORMAT=text
TWINS_LOG_OUTPUT=./data/twins.log
TWINS_LOG_MAX_SIZE=100
TWINS_LOG_MAX_BACKUPS=3
TWINS_LOG_COMPRESS=true
TWINS_LOG_DEBUG_CATEGORIES=
